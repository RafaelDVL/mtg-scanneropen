{
  "name": "mtg-scanneropen",
  "version": "0.0.0",
  "author": "Ionic Framework",
  "homepage": "https://ionicframework.com/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "ionic:build": "npm run build",
    "ionic:serve": "npm run start -- --open",
    "cap:build": "npm run build && npx cap sync",
    "cap:deploy": "npm run cap:build && cd android && .\\gradlew.bat assembleDebug && cd .. && adb -s bd283246466a install -r android\\app\\build\\outputs\\apk\\debug\\app-debug.apk",
    "cap:run": "npm run cap:deploy && adb -s bd283246466a shell am start -n mtg.scanneropen/.MainActivity"
  },
  "private": true,
